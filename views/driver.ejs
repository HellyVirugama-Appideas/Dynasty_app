<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">

<head>
    <%- include('_layouts/head') %>
        <title>Driver List | <%= title %>
        </title>
        <link rel="stylesheet" type="text/css" href="/app-assets/vendors/data-tables/css/jquery.dataTables.min.css">
        <link rel="stylesheet" type="text/css"
            href="/app-assets/vendors/data-tables/extensions/responsive/css/responsive.dataTables.min.css">
        <link rel="stylesheet" type="text/css" href="/app-assets/vendors/data-tables/css/select.dataTables.min.css">
        <link rel="stylesheet" type="text/css" href="/app-assets/css/pages/data-tables.css">
</head>

<body
    class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns"
    data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">

    <%- include('_layouts/sidenavbar') %>

        <!-- BEGIN: Page Main-->
        <div id="main">
            <div class="row">
                <div id="breadcrumbs-wrapper" data-image="/app-assets/images/gallery/breadcrumb-bg.jpg">
                    <div class="container">
                        <div class="row">
                            <div class="col s12 m6 l6">
                                <h5 class="breadcrumbs-title mt-0 mb-0"><span>Driver List</span></h5>
                            </div>
                            <!-- <div class="col s12 m6 l6 right-align-md">
                            <ol class="breadcrumbs mb-0">
                                <li class="breadcrumb-item"><a href="/admin">Home</a></li>
                                <li class="breadcrumb-item active">Driver</li>
                            </ol>
                        </div> -->
                            <div class="col s12 m6 l6 right-align-md">
                                <ol class="breadcrumbs mb-0">
                                    <a class="btn gradient-45deg-purple-deep-orange pull-right btn-breadcrumbs" style="color:#fff;"
                                        href="/admin/driver/add">Create New Driver</a>
                                </ol>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col s12">
                    <div class="container">
                        <div class="section section-data-tables">
                            <div class="row">
                                <div class="col s12">
                                    <div class="card">
                                        <div class="card-content">
                                            <%- messages('messages', locals) %>

                                                <div class="row">
                                                    <div class="col s12 overflow">
                                                        <table id="page-length-option" class="display">
                                                            <thead>
                                                                <tr>
                                                                    <th>Sr</th>
                                                                    <th>Profile</th>
                                                                    <th>Name</th>
                                                                    <th>Mobile</th>
                                                                    <th>Email</th>
                                                                    <th>Date</th>
                                                                    <th>Action</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                <% for(let i=0; i < drivers.length; i++) { const
                                                                    driver=drivers[i]; %>
                                                                    <tr>
                                                                        <td>
                                                                            <%= i + 1 %>
                                                                        </td>
                                                                        <td>
                                                                            <!-- SQUARE IMAGE -->
                                                                            <img src="<%= driver.profile %>"
                                                                                alt="profile" width="40" height="40"
                                                                                class="responsive-img"
                                                                                style="object-fit: cover;"
                                                                                onerror="this.src='/uploads/default_user.jpg';">
                                                                        </td>
                                                                        <td>
                                                                            <%= driver.name %>
                                                                        </td>
                                                                        <td>
                                                                            <%= driver.country_code %>
                                                                                <%= driver.phone %>
                                                                        </td>
                                                                        <td>
                                                                            <%= driver.email %>
                                                                        </td>
                                                                        <td>
                                                                            <%= driver.date.toLocaleDateString('en-GB')
                                                                                %>
                                                                        </td>

                                                                        <!-- ACTION -->
                                                                        <td style="white-space: nowrap;">
                                                                            <div
                                                                                style="display: flex; align-items: center; gap: 8px;">

                                                                                <!-- View -->
                                                                                <a href="/admin/driver/<%= driver._id %>"
                                                                                    class="waves-effect waves-light"
                                                                                    title="View">
                                                                                    <i class="material-icons"
                                                                                        style="font-size: 18px; color: #2196F3;">remove_red_eye</i>
                                                                                </a>

                                                                                <!-- Edit -->
                                                                                <a href="/admin/driver/edit/<%= driver._id %>"
                                                                                    class="waves-effect waves-light"
                                                                                    title="Edit">
                                                                                    <i class="material-icons"
                                                                                        style="font-size: 18px; color: #2196F3;">edit</i>
                                                                                </a>

                                                                                <!-- Delete -->
                                                                                <form
                                                                                    action="/admin/driver/delete/<%= driver._id %>?_method=DELETE"
                                                                                    method="POST"
                                                                                    style="display: inline; margin: 0;">
                                                                                    <button type="submit"
                                                                                        class="waves-effect waves-light"
                                                                                        style="background: none; border: none; padding: 0; margin: 0; cursor: pointer;"
                                                                                        title="Delete"
                                                                                        onclick="return confirm('Delete <%= driver.name %>?');">
                                                                                        <i class="material-icons"
                                                                                            style="font-size: 18px; color: #2196F3;">delete</i>
                                                                                    </button>
                                                                                </form>

                                                                                <!-- Block / Unblock -->
                                                                                <% if (driver.blocked) { %>
                                                                                    <a href="/admin/driver/unblock/<%= driver._id %>"
                                                                                        class="btn btn-small waves-effect waves-light"
                                                                                        style="background: linear-gradient(45deg, #4CAF50, #66BB6A); color: white; font-size: 11px; padding: 0 14px; height: 28px; line-height: 28px; border-radius: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); min-width: 64px; text-align: center;">
                                                                                        Unblock
                                                                                    </a>
                                                                                    <% } else { %>
                                                                                        <a href="/admin/driver/block/<%= driver._id %>"
                                                                                            class="btn btn-small waves-effect waves-light"
                                                                                            style="background: linear-gradient(45deg, #F44336, #EF5350); color: white; font-size: 11px; padding: 0 14px; height: 28px; line-height: 28px; border-radius: 14px; box-shadow: 0 2px 5px rgba(0,0,0,0.1); min-width: 64px; text-align: center;">
                                                                                            Block
                                                                                        </a>
                                                                                        <% } %>

                                                                            </div>
                                                                        </td>
                                                                    </tr>
                                                                    <% } %>
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="content-overlay"></div>
                </div>
            </div>
        </div>
        <!-- END: Page Main-->

        <%- include('_layouts/commonJs') %>
            <script src="/app-assets/vendors/data-tables/js/jquery.dataTables.min.js"></script>
            <script src="/app-assets/js/scripts/data-tables.js"></script>

            <!-- NO REINITIALIZATION ERROR -->
            <script>
                $(document).ready(function () {
                    if ($.fn.DataTable.isDataTable('#page-length-option')) {
                        $('#page-length-option').DataTable().destroy();
                    }

                    $('#page-length-option').DataTable({
                        "pageLength": 10,
                        "responsive": true,
                        "columnDefs": [
                            { "orderable": false, "targets": [1, 6] },
                            { "width": "5%", "targets": 0 },
                            { "width": "10%", "targets": 1 },
                            { "width": "20%", "targets": 2 },
                            { "width": "15%", "targets": 3 },
                            { "width": "20%", "targets": 4 },
                            { "width": "10%", "targets": 5 },
                            { "width": "20%", "targets": 6 }
                        ]
                    });
                });
            </script>
</body>

</html>