<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">
<!-- BEGIN: Head-->

<head>
    <%- include('_layouts/head') %>
    <title>Driver List | <%= title %></title>
    <link rel="stylesheet" type="text/css" href="/app-assets/vendors/data-tables/css/jquery.dataTables.min.css">
    <link rel="stylesheet" type="text/css" href="/app-assets/vendors/data-tables/extensions/responsive/css/responsive.dataTables.min.css">
    <link rel="stylesheet" type="text/css" href="/app-assets/vendors/data-tables/css/select.dataTables.min.css">
    <link rel="stylesheet" type="text/css" href="/app-assets/css/pages/data-tables.css">
</head>
<!-- END: Head-->

<body class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns" data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">

    <%- include('_layouts/sidenavbar') %>

    <!-- BEGIN: Page Main-->
    <div id="main">
        <div class="row">
            <div id="breadcrumbs-wrapper" data-image="/app-assets/images/gallery/breadcrumb-bg.jpg">
                <!-- Search for small screen-->
                <div class="container">
                    <div class="row">
                        <div class="col s12 m6 l6">
                            <h5 class="breadcrumbs-title mt-0 mb-0"><span>Driver List</span></h5>
                        </div>
                        <div class="col s12 m6 l6 right-align-md">
                            <a class="btn gradient-45deg-purple-deep-orange pull-right btn-breadcrumbs" href="/admin/driver/add">Add Driver</a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col s12">
                <div class="container">
                    <div class="section section-data-tables">
                        <!-- Page Length Options -->
                        <div class="row">
                            <div class="col s12">
                                <div class="card">
                                    <div class="card-content">
                                        <%- messages('messages', locals) %>
                                        <div class="row">
                                            <div class="col s12 overflow">
                                                <table id="page-length-option" class="display">
                                                    <thead>
                                                        <tr>
                                                            <th>Sr</th>
                                                            <th>Profile</th>
                                                            <th>User Name</th>
                                                            <th>Mobile</th>
                                                            <th>Email</th>
                                                            <th>Date</th>
                                                            <th>Edit</th>
                                                            <th>Status</th>
                                                            <th>Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% for( let i=0; i < drivers.length; i++ ) { %>
                                                        <tr>
                                                            <td><%= i+1 %></td>
                                                            <td><img src="<%= drivers[i].profile %>" alt="alt" width="50" onerror="this.onerror=null; this.src='/uploads/default_user.jpg';"></td>
                                                            <td><%= drivers[i].name %></td>
                                                            <td><%= drivers[i].country_code + " " + drivers[i].phone %></td>
                                                            <td><%= drivers[i].email %></td>
                                                            <td><%= drivers[i].date.toLocaleDateString('en-GB') %></td>
                                                            <td style="max-width: 50px;"><a href="/admin/driver/edit/<%= drivers[i].id %>"><i class="material-icons">edit</i></a></td>
                                                            <td>
                                                                <% if (drivers[i].approved) { %>
                                                                Approved
                                                                <% } else { %>
                                                                <a href="/admin/driver/approve/<%= drivers[i].id %>" class="waves-effect border-round waves-light btn gradient-45deg-green-teal" onclick="return confirm('Are you sure want to approve this driver?');">Approve</a>
                                                                <% } %>
                                                            </td>
                                                            <td>
                                                                <% if (drivers[i].blocked) { %>
                                                                <a href="/admin/driver/unblock/<%= drivers[i].id %>" class="waves-effect border-round waves-light btn gradient-45deg-green-teal" onclick="return confirm('Are you sure want to unblock this driver?');">unblock</a>
                                                                <% } else { %>
                                                                <a href="/admin/driver/block/<%= drivers[i].id %>" class="waves-effect border-round waves-light btn gradient-45deg-red-pink" onclick="return confirm('Are you sure want to block this driver?');">block</a>
                                                                <% } %>
                                                            </td>
                                                        </tr>
                                                        <% } %>
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="content-overlay"></div>
            </div>
        </div>
    </div>
    <!-- END: Page Main-->

    <%- include('_layouts/commonJs') %>
    <script src="/app-assets/vendors/data-tables/js/jquery.dataTables.min.js"></script>
    <script src="/app-assets/js/scripts/data-tables.js"></script>
</body>

</html>