<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">
<!-- BEGIN: Head-->

<head>
    <%- include('_layouts/head') %>
    <title>Add Driver | <%= title %></title>
    <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.2/css/dropify.min.css">
</head>
<!-- END: Head-->

<body class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns" data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">
    <%- include('_layouts/sidenavbar') %>

    <!-- BEGIN: Page Main-->
    <div id="main">
        <div class="row">
            <div id="breadcrumbs-wrapper" data-image="/app-assets/images/gallery/breadcrumb-bg.jpg">
                <div class="container">
                    <div class="row">
                        <div class="col s12 m6 l6">
                            <h5 class="breadcrumbs-title mt-0 mb-0"><span>Add Driver</span></h5>
                        </div>
                        <div class="col s12 m6 l6 right-align-md">
                            <ol class="breadcrumbs mb-0">
                                <li class="breadcrumb-item"><a href="/admin">Home</a></li>
                                <li class="breadcrumb-item"><a href="/admin/driver">Driver</a></li>
                                <li class="breadcrumb-item active">Add Driver</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            <div class="">
                <div class="container">
                    <div class="section">
                        <div class="row">
                            <div class="col s12">
                                <%- messages('messages', locals) %>
                            </div>
                        </div>
                        <form method="POST" onsubmit="validate()" action="/admin/driver/add" id="form" enctype="multipart/form-data">
                            <div class="col s12">
                                <div class="card">
                                    <div class="card-content">
                                        <div class="row">
                                            <div class="input-field col m6 s12">
                                                <input placeholder="Name" id="name" name="name" type="text">
                                                <label for="name">Name</label>
                                                <small>
                                                    <div id="error1" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                <input placeholder="email" id="email" name="email" type="text">
                                                <label for="email">Email</label>
                                                <small>
                                                    <div id="error2" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                <input placeholder="Country code" id="country_code" name="country_code" type="text">
                                                <label for="country_code">Country code</label>
                                                <small>
                                                    <div id="error3" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                <input placeholder="Mobile number" id="phone" name="phone" type="text" oninput="this.value = this.value.replace(/[^0-9]/g, '')">
                                                <label for="phone">Mobile number</label>
                                                <small>
                                                    <div id="error4" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                <select id="country" name="country">
                                                    <option value="">Select country</option>
                                                    <% for( let i = 0; i < countries.length; i++ ) { %>
                                                    <option value="<%= countries[i]._id %>"><%= countries[i].en.name %></option>
                                                    <% } %>
                                                </select>
                                                <label>Select country</label>
                                                <small>
                                                    <div id="error5" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                <select id="city" name="city">
                                                    <option value="">Select city</option>
                                                </select>
                                                <label>Select city</label>
                                                <small>
                                                    <div id="error6" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                <input placeholder="Address" id="address" name="address" type="text">
                                                <label for="address">Address</label>
                                                <small>
                                                    <div id="error12" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                <select id="type" name="type">
                                                    <option value="">Select vehicle type</option>
                                                    <% for( let i = 0; i < types.length; i++ ) { %>
                                                    <option value="<%= types[i]._id %>"><%= types[i].en.name %></option>
                                                    <% } %>
                                                </select>
                                                <label>Select vehicle type</label>
                                                <small>
                                                    <div id="error7" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                Profile Photo
                                                <input type="file" accept="image/png, image/jpeg" name="profile" id="profile" class="dropify" data-disable-remove="true" required />
                                                <small>
                                                    <div id="error8" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                Driver Licence - Front
                                                <input type="file" accept="image/png, image/jpeg" name="licence" id="licence" class="dropify" data-disable-remove="true" required />
                                                <small>
                                                    <div id="error9" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                Pan card
                                                <input type="file" accept="image/png, image/jpeg" name="pan" id="pan" class="dropify" data-disable-remove="true" required />
                                                <small>
                                                    <div id="error10" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m6 s12">
                                                Regestration certificate
                                                <input type="file" accept="image/png, image/jpeg" name="rc" id="rc" class="dropify" data-disable-remove="true" required />
                                                <small>
                                                    <div id="error11" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="col s12">
                                                <button type="submit" class="btn purple" id="submitBtn">Submit</button>
                                                <a onclick="history.back()" class="btn btn-danger ml-1">Cancel</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="content-overlay"></div>
            </div>
        </div>
    </div>
    <!-- END: Page Main-->

    <input id="hidden" cols="30" rows="10" value="<%= JSON.stringify(cities) %>" hidden></input>
    <%- include('_layouts/commonJs') %>
    <script>
        const data = JSON.parse(document.getElementById('hidden').value);
        const city = document.getElementById('city');
        let instance = M.FormSelect.init(city);

        function setCityOptions() {
            if (this.value == '') {
                city.innerHTML = '<option value="">Select city</option>';
            } else {
                city.innerHTML = '<option value="">Select city</option>';
                const cities = data.find(item => item._id == this.value)?.cities;
                if (cities) {
                    for (let i = 0; i < cities.length; i++) {
                        let z = document.createElement('option');
                        z.value = `${cities[i]._id}`;
                        z.text = `${cities[i].name}`;
                        city.appendChild(z);
                    }
                }
            }
            instance = M.FormSelect.init(city);
        }
        document.getElementById('country').addEventListener('change', setCityOptions);

        const formC = document.getElementById('form');

        formC.addEventListener('submit', (e) => {
            e.preventDefault();
        })

        function validate() {
            let returnVal = true;

            const nameValue = document.getElementById('name').value.trim();
            const emailValue = document.getElementById('email').value.trim();
            const countryCodeValue = document.getElementById('country_code').value.trim();
            const phoneValue = document.getElementById('phone').value.trim();
            // const countryValue = document.getElementById('country').value.trim();
            // const cityValue = document.getElementById('city').value.trim();
            const addressValue = document.getElementById('address').value.trim();
            // const typeValue = document.getElementById('type').value.trim();
            const profileFileValue = document.getElementById('profile').value;
            const profileExt = profileFileValue.substring(profileFileValue.lastIndexOf('.') + 1);
            const licenceFileValue = document.getElementById('licence').value;
            const licenceExt = licenceFileValue.substring(licenceFileValue.lastIndexOf('.') + 1);
            const panFileValue = document.getElementById('pan').value;
            const panExt = panFileValue.substring(panFileValue.lastIndexOf('.') + 1);
            const rcFileValue = document.getElementById('rc').value;
            const rcExt = rcFileValue.substring(rcFileValue.lastIndexOf('.') + 1);

            if (nameValue == '') {
                document.getElementById('error1').innerText = 'Please enter driver name.';
                returnVal = false;
            } else {
                document.getElementById('error1').innerText = '';
            }

            if (emailValue == '') {
                document.getElementById('error2').innerText = 'Please enter email.';
                returnVal = false;
            } else if (!validateEmail(emailValue)) {
                document.getElementById('error2').innerText = 'Please enter valid email.';
                returnVal = false;
            } else {
                document.getElementById('error2').innerText = '';
            }

            if (countryCodeValue == '') {
                document.getElementById('error3').innerText = 'Please enter country code.';
                returnVal = false;
            } else {
                document.getElementById('error3').innerText = '';
            }

            if (phoneValue == '') {
                document.getElementById('error4').innerText = 'Please enter mobile number.';
                returnVal = false;
            } else {
                document.getElementById('error4').innerText = '';
            }

            // if (countryValue == '') {
            //     document.getElementById('error5').innerText = 'Please select country.';
            //     returnVal = false;
            // } else {
            //     document.getElementById('error5').innerText = '';
            // }

            // if (cityValue == '') {
            //     document.getElementById('error6').innerText = 'Please select city.';
            //     returnVal = false;
            // } else {
            //     document.getElementById('error6').innerText = '';
            // }

            if (addressValue == '') {
                document.getElementById('error12').innerText = 'Please enter address.';
                returnVal = false;
            } else {
                document.getElementById('error12').innerText = '';
            }

            // if (typeValue == '') {
            //     document.getElementById('error7').innerText = 'Please select vehicle type.';
            //     returnVal = false;
            // } else {
            //     document.getElementById('error7').innerText = '';
            // }

            if (profileExt == 'png' || profileExt == 'jpeg' || profileExt == 'jpg') {
                document.getElementById('error8').innerText = '';
            } else {
                document.getElementById('error8').innerText = 'Wrong file type.';
                returnVal = false;
            }

            if (licenceExt == 'png' || licenceExt == 'jpeg' || licenceExt == 'jpg') {
                document.getElementById('error9').innerText = '';
            } else {
                document.getElementById('error9').innerText = 'Wrong file type.';
                returnVal = false;
            }
            if (panExt == 'png' || panExt == 'jpeg' || panExt == 'jpg') {
                document.getElementById('error10').innerText = '';
            } else {
                document.getElementById('error10').innerText = 'Wrong file type.';
                returnVal = false;
            }
            if (rcExt == 'png' || rcExt == 'jpeg' || rcExt == 'jpg') {
                document.getElementById('error11').innerText = '';
            } else {
                document.getElementById('error11').innerText = 'Wrong file type.';
                returnVal = false;
            }

            if (returnVal) {
                document.getElementById('submitBtn').disabled = true;
                formC.submit();
            }
        }

        function validateEmail(email) {
            return email.match(
                /^(([^<>()[\]\\.,;:\s@\"]+(\.[^<>()[\]\\.,;:\s@\"]+)*)|(\".+\"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/
            );
        }
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.2/js/dropify.min.js"></script>
    <script src="/app-assets/js/scripts/form-file-uploads.min.js"></script>
</body>

</html>