                <div class="col-md-12 contact-form">
                    <form id="ajax-contact" method="post" action="/contact">
                        <div class="form-group">
                            <div class="row">
                                <div class="col-sm-6 wow fadeInUp" data-wow-duration="1.5s" data-wow-delay=".3s">
