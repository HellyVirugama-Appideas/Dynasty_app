<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">
<!-- BEGIN: Head-->

<head>
    <%- include('_layouts/head') %>
    <title>User View | <%= title %></title>
    <link rel="stylesheet" type="text/css" href="/app-assets/css/pages/page-users.css">
    <link rel="stylesheet" type="text/css" href="/app-assets/vendors/magnific-popup/magnific-popup.css">
</head>
<!-- END: Head-->

<body class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns" data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">

    <%- include('_layouts/sidenavbar') %>

    <!-- BEGIN: Page Main-->
    <div id="main">
        <div class="row">
            <div id="breadcrumbs-wrapper" data-image="/app-assets/images/gallery/breadcrumb-bg.jpg">
                <!-- Search for small screen-->
                <div class="container">
                    <div class="row">
                        <div class="col s12 m6 l6">
                            <h5 class="breadcrumbs-title mt-0 mb-0"><span>User View</span></h5>
                        </div>
                        <div class="col s12 m6 l6 right-align-md">
                            <ol class="breadcrumbs mb-0">
                                <li class="breadcrumb-item"><a href="/">Home</a></li>
                                <li class="breadcrumb-item"><a href="/user">User</a></li>
                                <li class="breadcrumb-item active">User Details</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col s12">
                <div class="container">
                    <!-- users view start -->
                    <div class="section users-view">
                        <!-- users view media object start -->
                        <div class="card-panel">
                            <div class="row">
                                <div class="col s12 m7">
                                    <div class="display-flex media">
                                        <img src="<%= user.profile %>" alt="users view avatar" class="z-depth-2 circle mr-3" height="64" width="64" onerror="this.onerror=null; this.src='/uploads/default_user.jpg';">
                                        <div class="media-body">
                                            <h6 class="media-heading">
                                                <span class="users-view-name"><%= user.name %></span>
                                            </h6>
                                            <span>Mobile:</span>
                                            <span class="users-view-id"><%= user.country_code + " " + user.phone %></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <!-- users view media object ends -->

                        <!-- users view card details start -->
                        <div class="card">
                            <div class="card-content">
                                <div class="row">
                                    <div class="col s12">
                                        <table class="striped">
                                            <tbody>
                                                <tr>
                                                    <th style="width: 200px;">Name</th>
                                                    <td><%= user.name %></td>
                                                </tr>
                                                <tr>
                                                    <th>Mobile</th>
                                                    <td><%= user.country_code + " " + user.phone %></td>
                                                </tr>
                                                <tr>
                                                    <th>E-mail</th>
                                                    <td><%= user.email %></td>
                                                </tr>
                                                <tr>
                                                    <th>City</th>
                                                    <td><%= user.city?.en?.name || '-' %></td>
                                                </tr>
                                                <tr>
                                                    <th>Country</th>
                                                    <td><%= user.country?.en?.name || '-' %></td>
                                                </tr>
                                                <tr>
                                                    <th>Date</th>
                                                    <td><%= user.date.toLocaleDateString('en-GB') %></td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                                <div class="row">
                                    <a onclick="history.back()" class="btn btn-danger mt-2" style="margin-left: 15px;">Back</a>
                                </div>
                            </div>
                        </div>
                        <!-- users view card details ends -->
                        <div class="card">
                            <div class="card-content">
                                <% if (!user.licenseFront || !user.licenseBack) { %>
                                <h6 class="mb-1 mt-2">No License Images.</h6>
                                <% } else { %>
                                <h6 class="mb-1 mt-2">License Images:</h6>
                                <div class="masonry-gallery-wrapper">
                                    <div class="popup-gallery">
                                        <div class="gallery-sizer"></div>
                                        <div class="row">
                                            <div class="col s12 m6 l4 xl2">
                                                <div>
                                                    <a href="<%= user.licenseFront %>" title="licenseFront">
                                                        <img src="<%= user.licenseFront %>" class="responsive-img mb-10" alt="licenseFront">
                                                    </a>
                                                </div>
                                            </div>
                                            <div class="col s12 m6 l4 xl2">
                                                <div>
                                                    <a href="<%= user.licenseBack %>" title="licenseBack">
                                                        <img src="<%= user.licenseBack %>" class="responsive-img mb-10" alt="licenseBack">
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                    <!-- users view ends -->
                </div>
                <div class="content-overlay"></div>
            </div>
        </div>
    </div>
    <!-- END: Page Main-->

    <%- include('_layouts/commonJs')  %>
    <script src="/app-assets/vendors/magnific-popup/jquery.magnific-popup.min.js"></script>
    <script src="/app-assets/vendors/imagesloaded.pkgd.min.js"></script>
    <script src="/app-assets/js/scripts/media-gallery-page.js"></script>
</body>

</html>