<style>
    .notification-badge {
        position: absolute;
        top: 5px;
        right: 46px;
        background-color: red;
        border-radius: 50%;
        width: 15px;
        height: 15px;
        animation: pulse 1s infinite;
    }

    @keyframes pulse {
        0%, 100% { transform: scale(1); }
        50%      { transform: scale(1.3); }
    }
</style>

