<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">
<!-- BEGIN: Head-->

<head>
    <%- include('_layouts/head') %>
    <title>Add Country | <%= title %></title>
    <link rel="stylesheet" type="text/css" href="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.2/css/dropify.min.css">
</head>
<!-- END: Head-->

<body class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns" data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">
    <%- include('_layouts/sidenavbar') %>

    <!-- BEGIN: Page Main-->
    <div id="main">
        <div class="row">
            <div id="breadcrumbs-wrapper" data-image="/app-assets/images/gallery/breadcrumb-bg.jpg">
                <div class="container">
                    <div class="row">
                        <div class="col s12 m6 l6">
                            <h5 class="breadcrumbs-title mt-0 mb-0"><span>Add Country</span></h5>
                        </div>
                        <div class="col s12 m6 l6 right-align-md">
                            <ol class="breadcrumbs mb-0">
                                <li class="breadcrumb-item"><a href="/admin">Home</a></li>
                                <li class="breadcrumb-item"><a href="/admin/country">Country</a></li>
                                <li class="breadcrumb-item active">Add Country</li>
                            </ol>
                        </div>
                    </div>
                </div>
            </div>
            <div class="">
                <div class="container">
                    <div class="section">
                        <div class="row">
                            <div class="col s12">
                                <%- messages('messages', locals) %>
                            </div>
                        </div>
                        <form method="POST" onsubmit="validate()" action="/admin/country/add" id="form" enctype="multipart/form-data">
                            <div class="col s12">
                                <div class="card">
                                    <div class="card-content">
                                        <div class="row">
                                            <div class="input-field col m4 s12">
                                                <input placeholder="Name (English)" id="nameEn" name="nameEn" type="text">
                                                <label for="nameEn">Name</label>
                                                <small>
                                                    <div id="error1" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m4 s12">
                                                <input placeholder="Name (French)" id="nameFr" name="nameFr" type="text">
                                                <label for="nameFr">Name</label>
                                                <small>
                                                    <div id="error2" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col m4 s12">
                                                <input placeholder="Name (Arabic)" id="nameAr" name="nameAr" type="text">
                                                <label for="nameAr">Name</label>
                                                <small>
                                                    <div id="error3" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="input-field col s12">
                                                Upload Image
                                                <input type="file" accept="image/png, image/jpeg" name="image" id="input-file-now" class="dropify" data-disable-remove="true" required />
                                                <small>
                                                    <div id="error4" class="error"></div>
                                                </small>
                                            </div>
                                            <div class="col s12">
                                                <button type="submit" class="btn purple" id="submitBtn">Submit</button>
                                                <a onclick="history.back()" class="btn btn-danger ml-1">Cancel</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="content-overlay"></div>
            </div>
        </div>
    </div>
    <!-- END: Page Main-->

    <script>
        const formC = document.getElementById('form');

        formC.addEventListener('submit', (e) => {
            e.preventDefault();
        })

        function validate() {
            let returnVal = true;

            const nameEnValue = document.getElementById('nameEn').value.trim();
            const nameFrValue = document.getElementById('nameFr').value.trim();
            const nameArValue = document.getElementById('nameAr').value.trim();
            const fileValue = document.getElementById('input-file-now').value;
            const ext = fileValue.substring(fileValue.lastIndexOf('.') + 1).toLowerCase();

            if (nameEnValue == '') {
                document.getElementById('error1').innerText = 'Please enter country name.';
                returnVal = false;
            } else {
                document.getElementById('error1').innerText = '';
            }

            if (nameFrValue == '') {
                document.getElementById('error2').innerText = 'Please enter country name.';
                returnVal = false;
            } else {
                document.getElementById('error2').innerText = '';
            }

            if (nameArValue == '') {
                document.getElementById('error3').innerText = 'Please enter country name.';
                returnVal = false;
            } else {
                document.getElementById('error3').innerText = '';
            }

            if (ext == 'png' || ext == 'jpeg' || ext == 'jpg') {
                document.getElementById('error4').innerText = '';
            } else {
                document.getElementById('error4').innerText = 'Wrong file type.';
                returnVal = false;
            }

            if (returnVal) {
                document.getElementById('submitBtn').disabled = true;
                formC.submit();
            }
        }
    </script>
    <%- include('_layouts/commonJs') %>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Dropify/0.2.2/js/dropify.min.js"></script>
    <script src="/app-assets/js/scripts/form-file-uploads.min.js"></script>
</body>

</html>